# Persistent Memory MCP
# Copy this file to .env or run: memory-mcp init

# Required Supabase backend
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Use a stable unique identifier. Do not use secrets or passwords.
OWNER_ID=your-github-username-or-workspace-id

# Optional direct PostgreSQL connection for admin scripts and SQL tooling
DATABASE_URL=

# Optional runtime configuration
LOG_LEVEL=INFO
PROJECT_MEMORY_INTERFACE=native

# Recommended privacy defaults for future-compatible clients
MEMORY_REDACT_SECRETS=true
MEMORY_IGNORE=.env,*.pem,*.key,secrets/**
MEMORY_DEFAULT_RETENTION_DAYS=90
